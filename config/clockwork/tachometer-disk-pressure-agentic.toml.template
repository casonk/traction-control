[[jobs]]
name = "tachometer-disk-pressure-agentic"
description = "Agentic remediation for tachometer disk-pressure alerts in clean portfolio repos"
scope = "user"
service_type = "oneshot"
working_directory = "__REPO_ROOT__"
exec_start = "__REPO_ROOT__/scripts/tachometer_disk_pressure_agentic.sh"
after = ["network-online.target"]
wants = ["network-online.target"]
environment_files = ["-%h/.config/traction-control/tachometer-disk-pressure-agentic.env"]
standard_output = "journal"
standard_error = "journal"
timer_description = "Run tachometer disk-pressure agentic remediation"

[jobs.environment]
PORTFOLIO_ROOT = "__PORTFOLIO_ROOT__"
LOG_DIR = "%h/.local/share/tachometer-disk-pressure-agentic"
TACHOMETER_DISK_PRESSURE_AGENTIC_PROVIDER = "__PROVIDER__"
TACHOMETER_DISK_PRESSURE_AGENTIC_MODEL = "__MODEL__"

[jobs.timer]
kind = "interval"
on_boot_sec = "110m"
on_unit_active_sec = "6h"
persistent = true
randomized_delay_sec = "1200"
