[Unit]
Description=Run archility weekly architecture audit and diagram render
Documentation=https://github.com/casonk/traction-control

[Timer]
# Every Sunday at 02:00 local time
OnCalendar=Sun *-*-* 02:00:00
# If a run was missed (machine off), catch up within 1 hour of next boot
Persistent=true
RandomizedDelaySec=600

[Install]
WantedBy=timers.target
